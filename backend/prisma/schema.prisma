generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MEMBER)
  tasks     Task[]
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      Status   @default(TODO)
  dueDate     DateTime
  priority    String
  assignedTo  Int

  user        User     @relation(fields: [assignedTo], references: [id])
}

enum Role {
  ADMIN
  MEMBER
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}